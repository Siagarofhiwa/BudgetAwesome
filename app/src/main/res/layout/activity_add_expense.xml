<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➕ New Expense Entry"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:layout_marginBottom="18dp" />

            <!-- Date -->
            <TextView
                style="@style/LabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATE *" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    android:paddingStart="14dp" />

                <Button
                    android:id="@+id/btnPickDate"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Pick Date"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:background="@drawable/bg_ghost_button"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />
            </LinearLayout>

            <!-- Start / End Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        style="@style/LabelText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="START TIME *" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvStartTime"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/btnPickStartTime"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Set"
                            android:textSize="11sp"
                            android:textColor="@color/textSecondary"
                            android:background="@drawable/bg_ghost_button"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        style="@style/LabelText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="END TIME *" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvEndTime"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/btnPickEndTime"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Set"
                            android:textSize="11sp"
                            android:textColor="@color/textSecondary"
                            android:background="@drawable/bg_ghost_button"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Category -->
            <TextView
                style="@style/LabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATEGORY *" />

            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="14dp" />

            <!-- Description -->
            <TextView
                style="@style/LabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIPTION *" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textSecondary"
                android:hint="What did you spend on?"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textCapSentences"
                android:layout_marginBottom="14dp" />

            <!-- Amount -->
            <TextView
                style="@style/LabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AMOUNT (R) *" />

            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textSecondary"
                android:hint="0.00"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="18dp" />

            <!-- Photo section -->
            <TextView
                style="@style/LabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHOTO (OPTIONAL)" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnCamera"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="📷 Camera"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:background="@drawable/bg_ghost_button"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="10dp" />

                <Button
                    android:id="@+id/btnGallery"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="🖼️ Gallery"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:background="@drawable/bg_ghost_button"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />
            </LinearLayout>

            <!-- Photo preview -->
            <LinearLayout
                android:id="@+id/layoutPhoto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivPhotoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnRemovePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="✕ Remove Photo"
                    android:textSize="12sp"
                    android:textColor="#F87171"
                    android:background="@drawable/bg_danger_button"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />
            </LinearLayout>

            <!-- Save button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✓ SAVE EXPENSE"
                android:textColor="@color/bgDark"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/bg_gold_button"
                android:layout_marginTop="6dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
